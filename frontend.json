{
    "id": "your-micro-app",
    "code": "your-micro-app",
    "name": "示例微应用",
    "version": "0.1.5",
    "enabled": true,
    "kind": "micro-app",
    "runtime": "wujie",
    "routeBase": "/your-micro-app",
    "meta": {
        "icon": "Monitor",
        "order": 100,
        "preload": false,
        "description": "用于演示微应用插件脚手架的最小实现。",
        "develop": true
    },
    "entry": {
        "wujie": {
            "name": "your_micro_app",
            "url": "http://localhost:5182/",
            "alive": true,
            "degrade": false,
            "sync": true
        }
    },
    "capabilities": {
        "routes": false,
        "pages": false,
        "widgets": false,
        "settings": false
    },
    "compatibility": {
        "console": ">=0.1.5"
    }
}
