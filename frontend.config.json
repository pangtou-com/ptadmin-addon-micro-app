{
    "enabled": true,
    "runtime": "wujie",
    "routeBase": "/your-micro-app",
    "meta": {
        "icon": "Monitor",
        "order": 100,
        "preload": false
    },
    "entry": {
        "wujie": {
            "name": "your_micro_app",
            "url": "http://localhost:5182/",
            "alive": true,
            "degrade": false,
            "sync": true
        }
    },
    "capabilities": {
        "pages": false,
        "widgets": false,
        "settings": false
    },
    "compatibility": {
        "console": ">=0.1.2"
    }
}
